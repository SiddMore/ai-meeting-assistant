# ─────────────────────────────────────────────────────────────────────────────
# AI Meeting Assistant — Backend Environment Variables
# Copy this file to .env and fill in all values before running.
# NEVER commit the actual .env file to source control.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
DEBUG=False
SECRET_KEY=CHANGE_ME_openssl_rand_hex_32
ALLOWED_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=meetingadmin
POSTGRES_PASSWORD=CHANGE_ME_strong_password
POSTGRES_DB=meeting_assistant
DATABASE_URL=postgresql+asyncpg://meetingadmin:CHANGE_ME_strong_password@db:5432/meeting_assistant
DATABASE_URL_SYNC=postgresql+psycopg2://meetingadmin:CHANGE_ME_strong_password@db:5432/meeting_assistant

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_redis_password
REDIS_URL=redis://:CHANGE_ME_redis_password@redis:6379/0

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Encryption (for OAuth refresh tokens at rest) ─────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=CHANGE_ME_fernet_key

# ── Google OAuth2 ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# ── Microsoft OAuth2 ──────────────────────────────────────────────────────────
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI=http://localhost:8000/api/v1/auth/microsoft/callback

# ── AI Services ───────────────────────────────────────────────────────────────
GOOGLE_AI_API_KEY=AIzaSyDMBREgtU2y7aRFzzBSWY2z0JgqVlRFG3k                           # Gemini 1.5 Pro
OPENAI_API_KEY=                              # GPT-4o fallback / Whisper
DEEPL_API_KEY=                              # Translation
REPLICATE_API_TOKEN=                         # Whisper via Replicate

# ── Meeting Bot (Recall.ai) ───────────────────────────────────────────────────
BOT_PROVIDER=mock
RECALL_AI_API_KEY=
RECALL_AI_REGION=us-east-1           # optional region identifier
RECALL_AI_WEBHOOK_URL=https://your-public-url/api/v1/webhooks/recall

# ── Storage (Cloudflare R2 / AWS S3) ─────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=ai-meeting-assistant
R2_PUBLIC_URL=https://pub-XXXX.r2.dev

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=noreply@yourdomain.com
EMAIL_FROM_NAME=AI Meeting Assistant
